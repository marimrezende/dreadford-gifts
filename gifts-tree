/* ============================ LAYOUT ============================ */
const SC = 0.265;                 // reference px -> world px
const NW = 260, NH = 88;          // node box size (world px)
const world = document.getElementById('world');
const edgesSvg = document.getElementById('edges');
const byId = {};
NODES.forEach(n=>{ n.x = n.cx*SC; n.y = n.cy*SC; byId[n.id]=n; });

// world bounds
let minX=1e9,minY=1e9,maxX=-1e9,maxY=-1e9;
NODES.forEach(n=>{ minX=Math.min(minX,n.x-NW/2); maxX=Math.max(maxX,n.x+NW/2);
                   minY=Math.min(minY,n.y-NH/2); maxY=Math.max(maxY,n.y+NH/2); });
const PAD=90;
const W = (maxX-minX)+PAD*2, H=(maxY-minY)+PAD*2;
const ox = -minX+PAD, oy=-minY+PAD;
NODES.forEach(n=>{ n.x+=ox; n.y+=oy; });
world.style.width=W+'px'; world.style.height=H+'px';
edgesSvg.setAttribute('width',W); edgesSvg.setAttribute('height',H);
edgesSvg.setAttribute('viewBox',`0 0 ${W} ${H}`);

// edges (orthogonal elbows)
const edgeEls=[];
EDGES.forEach(([a,b])=>{
  const pa=byId[a], pb=byId[b]; if(!pa||!pb) return;
  const x1=pa.x, y1=pa.y+NH/2, x2=pb.x, y2=pb.y-NH/2;
  const my=(y1+y2)/2;
  const d = `M ${x1} ${y1} L ${x1} ${my} L ${x2} ${my} L ${x2} ${y2}`;
  const p=document.createElementNS('http://www.w3.org/2000/svg','path');
  p.setAttribute('d',d); p.setAttribute('class','edge');
  edgesSvg.appendChild(p);
  edgeEls.push({el:p,a,b});
});

// nodes
NODES.forEach(n=>{
  const r=RANKS[n.rank];
  const el=document.createElement('div');
  el.className='node'; el.dataset.id=n.id;
  el.style.left=(n.x-NW/2)+'px'; el.style.top=(n.y-NH/2)+'px';
  el.style.background=r.color; el.style.color=r.text;
  el.innerHTML =
    `<span class="chk"></span>`+
    `<span class="xp">${n.xp}</span>`+
    `<div class="nm">${n.name}</div>`+
    `<div class="tg">${n.tag}</div>`;
  world.appendChild(el);
  n.el=el;
});

/* ============================ PAN / ZOOM ============================ */
const vp=document.getElementById('vp');
let scale=1, tx=0, ty=0;
function apply(){ world.style.transform=`translate(${tx}px,${ty}px) scale(${scale})`; if(activeNode) positionCard(activeNode); }
function fit(){
  const vw=vp.clientWidth, vh=vp.clientHeight;
  const s=Math.min(vw/W, vh/H)*0.92;
  scale=Math.max(0.12, Math.min(s,1.4));
  tx=(vw-W*scale)/2; ty=(vh-H*scale)/2 + 14;
  apply();
}
function zoomAt(cx,cy,factor){
  const ns=Math.max(0.15, Math.min(scale*factor, 2.4));
  const k=ns/scale;
  tx = cx - (cx-tx)*k; ty = cy - (cy-ty)*k; scale=ns; apply();
}
vp.addEventListener('wheel',e=>{ e.preventDefault();
  const r=vp.getBoundingClientRect();
  zoomAt(e.clientX-r.left, e.clientY-r.top, e.deltaY<0?1.12:1/1.12);
},{passive:false});
document.getElementById('zin').onclick =()=>zoomAt(vp.clientWidth/2,vp.clientHeight/2,1.2);
document.getElementById('zout').onclick=()=>zoomAt(vp.clientWidth/2,vp.clientHeight/2,1/1.2);
document.getElementById('fit').onclick =fit;

// drag pan (mouse + touch)
let dragging=false, moved=false, sx=0,sy=0,stx=0,sty=0, pid=null;
vp.addEventListener('pointerdown',e=>{
  if(e.target.closest('.node')) return;      // let node handle its own events
  dragging=true; moved=false; pid=e.pointerId; vp.setPointerCapture(pid);
  sx=e.clientX; sy=e.clientY; stx=tx; sty=ty; vp.classList.add('drag');
  hideHint();
});
vp.addEventListener('pointermove',e=>{
  if(!dragging) return;
  const dx=e.clientX-sx, dy=e.clientY-sy;
  if(Math.abs(dx)+Math.abs(dy)>3) moved=true;
  tx=stx+dx; ty=sty+dy; apply();
});
function endDrag(){ dragging=false; vp.classList.remove('drag'); }
vp.addEventListener('pointerup',e=>{ endDrag(); if(!moved && !e.target.closest('.node')) closeCard(); });
vp.addEventListener('pointercancel',endDrag);

// pinch zoom
const active=new Map(); let pinchDist=0, pinchMid=null;
vp.addEventListener('pointerdown',e=>active.set(e.pointerId,e));
vp.addEventListener('pointermove',e=>{
  if(!active.has(e.pointerId)) return; active.set(e.pointerId,e);
  if(active.size===2){
    const [p,q]=[...active.values()];
    const d=Math.hypot(p.clientX-q.clientX,p.clientY-q.clientY);
    const r=vp.getBoundingClientRect();
    const mid={x:(p.clientX+q.clientX)/2-r.left,y:(p.clientY+q.clientY)/2-r.top};
    if(pinchDist){ zoomAt(mid.x,mid.y,d/pinchDist); }
    pinchDist=d; pinchMid=mid; dragging=false;
  }
});
function clearPinch(e){ active.delete(e.pointerId); if(active.size<2) pinchDist=0; }
vp.addEventListener('pointerup',clearPinch);
vp.addEventListener('pointercancel',clearPinch);

/* ============================ DETAIL CARD ============================ */
const card=document.getElementById('card');
const cName=document.getElementById('c-name'), cSub=document.getElementById('c-sub'),
      cBody=document.getElementById('c-body'), cBar=document.getElementById('c-rankbar');
let activeNode=null, pinned=false, hideTimer=null;
const isMobile=()=>matchMedia('(max-width:720px)').matches;

function fillCard(n){
  const r=RANKS[n.rank];
  cBar.style.background=r.color;
  cName.textContent=n.name;
  cSub.innerHTML=`${r.label} &nbsp;·&nbsp; <b>${n.xp} XP</b>`;
  let html='';
  const st=n.stats||{};
  const keys=Object.keys(st);
  if(keys.length){
    html+='<div class="stats">'+keys.map(k=>`<span class="st"><b>${k}</b>${st[k]}</span>`).join('')+'</div>';
  }
  n.desc.forEach((p,i)=>{
    const cls = n.pending ? 'pending' : (i===0?'lead':'');
    html+=`<p class="${cls}">${p}</p>`;
  });
  cBody.innerHTML=html; cBody.scrollTop=0;
}
function positionCard(n){
  if(isMobile()){ card.style.left=''; card.style.top=''; return; }
  const rect=n.el.getBoundingClientRect();
  const cw=card.offsetWidth||340, ch=card.offsetHeight||400, gap=14;
  let left = rect.right+gap;
  if(left+cw>window.innerWidth-8) left = rect.left-gap-cw;
  if(left<8) left=8;
  let top = rect.top;
  if(top+ch>window.innerHeight-8) top=window.innerHeight-8-ch;
  if(top<62) top=62;
  card.style.left=left+'px'; card.style.top=top+'px';
}
function openCard(n,pin){
  activeNode=n; if(pin) pinned=true;
  NODES.forEach(x=>x.el.classList.toggle('active',x===n));
  highlightEdges(n.id);
  fillCard(n); card.classList.add('show'); positionCard(n);
}
function closeCard(){
  pinned=false; activeNode=null; card.classList.remove('show');
  NODES.forEach(x=>x.el.classList.remove('active'));
  highlightEdges(null);
}
document.getElementById('c-close').onclick=closeCard;
card.addEventListener('pointerenter',()=>{ if(hideTimer){clearTimeout(hideTimer);hideTimer=null;} });
card.addEventListener('pointerleave',()=>{ if(!pinned) scheduleHide(); });
function scheduleHide(){ hideTimer=setTimeout(()=>{ if(!pinned) closeCard(); },140); }

function highlightEdges(id){
  edgeEls.forEach(e=>{
    const hot = id && (e.a===id||e.b===id);
    e.el.classList.toggle('hot',!!hot);
  });
}

// node interactions
NODES.forEach(n=>{
  n.el.addEventListener('pointerenter',e=>{
    if(e.pointerType==='touch') return;
    if(hideTimer){clearTimeout(hideTimer);hideTimer=null;}
    if(!pinned) openCard(n,false);
  });
  n.el.addEventListener('pointerleave',e=>{
    if(e.pointerType==='touch') return;
    if(!pinned) scheduleHide();
  });
  n.el.addEventListener('click',e=>{
    e.stopPropagation();
    hideHint();
    if(activeNode===n && pinned){ closeCard(); }
    else { openCard(n,true); }
  });
});

/* ============================ SEARCH ============================ */
const q=document.getElementById('q');
if(q) q.addEventListener('input',()=>{
  const v=q.value.trim().toLowerCase();
  NODES.forEach(n=>{
    if(!v){ n.el.classList.remove('dim','match'); return; }
    const hit = n.name.toLowerCase().includes(v) || n.tag.toLowerCase().includes(v);
    n.el.classList.toggle('match',hit);
    n.el.classList.toggle('dim',!hit);
  });
});

/* ============================ LEGEND ============================ */
const legend=document.getElementById('legend');
const rankOrder=Object.entries(RANKS).sort((a,b)=>a[1].order-b[1].order);
const hidden=new Set();
rankOrder.forEach(([key,r])=>{
  const d=document.createElement('div'); d.className='lg'; d.dataset.rank=key;
  d.innerHTML=`<span class="sw" style="background:${r.color}"></span>${r.label}`;
  d.onclick=()=>{
    if(hidden.has(key)) hidden.delete(key); else hidden.add(key);
    d.classList.toggle('off',hidden.has(key));
    NODES.forEach(n=>{ n.el.style.display = hidden.has(n.rank)?'none':''; });
    edgeEls.forEach(e=>{
      const on = !hidden.has(byId[e.a].rank) && !hidden.has(byId[e.b].rank);
      e.el.style.display = on?'':'none';
    });
  };
  legend.appendChild(d);
});

/* ============================ INIT ============================ */
let hintGone=false;
function hideHint(){ if(hintGone) return; hintGone=true; const h=document.getElementById('hint'); if(h) h.classList.add('gone'); }
setTimeout(hideHint,6000);
window.addEventListener('resize',()=>{ if(activeNode) positionCard(activeNode); });
fit();
</script>
