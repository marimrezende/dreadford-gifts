<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>Loki's Guise — Gifts of the Blood</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0b0705;
    --bg2:#140b08;
    --ink:#f3e7db;
    --ink-dim:#b39a89;
    --line:#5a4136;
    --line-lit:#c8703c;
    --seal:#8a1418;
    --neophyte:#9b3320;
    --scion:#d8232a;
    --elder:#e8863a;
    --ascendant:#f2c24a;
    --ancevil:#efe256;
  }
  *{box-sizing:border-box}
  html,body{margin:0;height:100%;background:radial-gradient(120% 120% at 50% -10%, #1a0e09 0%, var(--bg) 55%, #060403 100%);color:var(--ink);font-family:"Spectral",Georgia,serif;overflow:hidden;-webkit-text-size-adjust:100%}

  /* ---- overlays ---- */
  .topbar{position:fixed;top:0;left:0;right:0;z-index:30;display:flex;align-items:center;gap:18px;padding:14px 20px;pointer-events:none;
    background:linear-gradient(180deg, rgba(6,4,3,.92) 0%, rgba(6,4,3,.55) 65%, transparent 100%)}
  .brand{pointer-events:none}
  .brand h1{font-family:"Cinzel",serif;font-weight:700;letter-spacing:.06em;margin:0;font-size:19px;color:#f0ddc9;text-shadow:0 1px 0 #000}
  .brand h1 .g{color:var(--line-lit)}
  .brand p{margin:2px 0 0;font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-dim)}

  .search{margin-left:auto;pointer-events:auto;position:relative}
  .search input{font-family:"Spectral",serif;font-size:14px;color:var(--ink);background:rgba(20,11,8,.9);border:1px solid var(--line);
    border-radius:2px;padding:8px 12px 8px 32px;width:210px;outline:none;transition:border-color .15s,box-shadow .15s}
  .search input:focus{border-color:var(--line-lit);box-shadow:0 0 0 2px rgba(200,112,60,.18)}
  .search input::placeholder{color:#8a7160;font-style:italic}
  .search svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);width:15px;height:15px;stroke:#8a7160}

  .legend{position:fixed;left:20px;bottom:18px;z-index:30;display:flex;flex-wrap:wrap;gap:6px 14px;max-width:min(92vw,560px);
    padding:11px 14px;background:rgba(10,6,4,.82);border:1px solid #2c1c14;border-radius:3px;backdrop-filter:blur(3px);pointer-events:auto}
  .legend .lg{display:flex;align-items:center;gap:7px;font-size:12px;letter-spacing:.03em;color:var(--ink-dim);cursor:pointer;user-select:none}
  .legend .sw{width:13px;height:13px;border-radius:2px;box-shadow:0 0 0 1px rgba(0,0,0,.4) inset}
  .legend .lg.off{opacity:.32}
  .legend .lg:hover{color:var(--ink)}

  .controls{position:fixed;right:18px;bottom:18px;z-index:30;display:flex;flex-direction:column;gap:7px}
  .controls button{width:38px;height:38px;font-size:18px;font-family:"Cinzel",serif;color:var(--ink);background:rgba(20,11,8,.9);
    border:1px solid var(--line);border-radius:3px;cursor:pointer;line-height:1;display:grid;place-items:center;transition:.15s}
  .controls button:hover{border-color:var(--line-lit);color:#fff;background:#20120c}
  .controls .fit{font-size:11px;letter-spacing:.05em}

  .hint{position:fixed;left:50%;top:64px;transform:translateX(-50%);z-index:25;font-size:12px;color:#7d6656;letter-spacing:.05em;
    pointer-events:none;opacity:1;transition:opacity .6s}
  .hint.gone{opacity:0}

  /* ---- canvas ---- */
  .viewport{position:absolute;inset:0;overflow:hidden;cursor:grab;touch-action:none}
  .viewport.drag{cursor:grabbing}
  .world{position:absolute;left:0;top:0;transform-origin:0 0;will-change:transform}
  svg.edges{position:absolute;left:0;top:0;overflow:visible;pointer-events:none}
  .edge{fill:none;stroke:var(--line);stroke-width:2}
  .edge.hot{stroke:var(--line-lit);stroke-width:3}

  .node{position:absolute;width:260px;height:88px;border-radius:5px;padding:9px 12px;cursor:pointer;
    display:flex;flex-direction:column;justify-content:center;text-align:center;
    box-shadow:0 4px 14px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.12);
    border:1px solid rgba(0,0,0,.35);transition:transform .12s ease, box-shadow .12s ease, filter .12s ease;}
  .node:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.16)}
  .node .nm{font-family:"Cinzel",serif;font-weight:600;font-size:14.5px;line-height:1.12;letter-spacing:.01em}
  .node .tg{font-size:11.5px;line-height:1.2;margin-top:4px;opacity:.82;font-style:italic}
  .node .xp{position:absolute;top:-9px;right:-9px;min-width:24px;height:24px;padding:0 5px;border-radius:13px;
    background:#120a07;border:1.5px solid currentColor;color:inherit;font-family:"Cinzel",serif;font-weight:700;font-size:12.5px;
    display:grid;place-items:center;box-shadow:0 2px 6px rgba(0,0,0,.5)}
  .node .chk{position:absolute;top:8px;left:8px;width:13px;height:13px;border-radius:2px;background:rgba(255,255,255,.9);
    box-shadow:0 0 0 1px rgba(0,0,0,.3);opacity:.55}
  .node.dim{filter:grayscale(.6) brightness(.5);opacity:.5}
  .node.match{outline:2px solid #fff;outline-offset:2px}
  .node.active{outline:2px solid #fff;outline-offset:2px}

  /* ---- detail card ---- */
  .card{position:fixed;z-index:40;width:340px;max-width:calc(100vw - 28px);max-height:min(78vh,620px);overflow:hidden;
    background:linear-gradient(180deg,#1b100a,#120a07);border:1px solid #3a2519;border-radius:6px;
    box-shadow:0 18px 50px rgba(0,0,0,.7);display:none;flex-direction:column}
  .card.show{display:flex}
  .card .head{padding:15px 18px 13px;border-bottom:1px solid #2c1c13;position:relative}
  .card .head .rankbar{height:4px;border-radius:2px;margin-bottom:11px;width:54px}
  .card h2{font-family:"Cinzel",serif;font-size:18px;font-weight:700;margin:0;line-height:1.12;letter-spacing:.01em;color:#f4e6d6;padding-right:26px}
  .card .sub{margin-top:5px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-dim)}
  .card .sub b{color:var(--line-lit);font-weight:600}
  .card .close{position:absolute;top:12px;right:12px;width:24px;height:24px;border:none;background:none;color:#7d6656;font-size:20px;
    cursor:pointer;line-height:1;display:none}
  .card .body{padding:14px 18px 18px;overflow-y:auto;font-size:14px;line-height:1.5}
  .card .stats{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
  .card .stats .st{font-size:11.5px;letter-spacing:.02em;padding:4px 9px;border:1px solid #3a2519;border-radius:12px;color:var(--ink);background:rgba(200,112,60,.08)}
  .card .stats .st b{color:var(--line-lit);font-weight:600;text-transform:uppercase;font-size:10px;letter-spacing:.06em;margin-right:4px}
  .card .body p{margin:0 0 9px}
  .card .body p:last-child{margin-bottom:0}
  .card .body .lead{color:#e9d6c4}
  .card .body .pending{color:#c98b5a;font-style:italic}
  .card .body::-webkit-scrollbar{width:8px}
  .card .body::-webkit-scrollbar-thumb{background:#3a2519;border-radius:4px}

  @media (max-width:720px){
    .brand h1{font-size:16px}
    .brand p{font-size:10.5px;letter-spacing:.1em}
    .search{display:none}
    .hint{display:none}
    .card{left:0!important;right:0;bottom:0;top:auto!important;width:100%;max-width:100%;max-height:70vh;border-radius:12px 12px 0 0;
      border-bottom:none}
    .card .close{display:block}
    .legend{left:10px;right:64px;bottom:10px;max-width:none}
    .controls{right:10px;bottom:10px}
  }
</style>
</head>
<body>
  <div class="topbar">
    <div class="brand">
      <h1>Loki<span class="g">'</span>s Guise <span style="color:#6f5647">·</span> <span style="font-weight:500;font-size:15px">Gifts of the Blood</span></h1>
      <p>Morgana — Árvore de Dádivas</p>
    </div>
    <div class="search">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input id="q" type="text" placeholder="Buscar dádiva…" autocomplete="off">
    </div>
  </div>

  <div class="hint" id="hint">Passe o mouse numa dádiva · arraste para navegar · scroll para zoom</div>

  <div class="viewport" id="vp">
    <div class="world" id="world">
      <svg class="edges" id="edges"></svg>
    </div>
  </div>

  <div class="legend" id="legend"></div>

  <div class="controls">
    <button id="zin" title="Aproximar">+</button>
    <button id="zout" title="Afastar">−</button>
    <button id="fit" class="fit" title="Enquadrar tudo">fit</button>
  </div>

  <div class="card" id="card">
    <div class="head">
      <div class="rankbar" id="c-rankbar"></div>
      <button class="close" id="c-close">×</button>
      <h2 id="c-name"></h2>
      <div class="sub" id="c-sub"></div>
    </div>
    <div class="body" id="c-body"></div>
  </div>

<script>
/* ============================ DATA ============================ */
const RANKS = {
  neophyte:{label:"Bloodling / Neophyte", color:"var(--neophyte)", text:"#fff",  order:1},
  scion:   {label:"Scion",                color:"var(--scion)",    text:"#fff",  order:2},
  elder:   {label:"Elder",                color:"var(--elder)",    text:"#180c06",order:3},
  ascendant:{label:"Ascendant",           color:"var(--ascendant)",text:"#180c06",order:4},
  ancevil: {label:"Anc Evil",             color:"var(--ancevil)",  text:"#180c06",order:5},
};

// cx,cy = pixel centre in the original 8000x7828 reference art (used only for layout)
const NODES = [
  {id:"hidden_arsenal", name:"Hidden Arsenal", rank:"neophyte", xp:1, cx:1122, cy:1356,
    tag:"Meld objects within yourself.",
    stats:{Cost:"1 Blood Point per Size of the object", Action:"Instant", Dice:"None"},
    desc:["The vampire can take inorganic matter into her body to conceal it, protect it, and otherwise keep it within her person.",
      "She can absorb an object up to one Size category beneath hers, two items two Size categories beneath her, or four that are three Size categories beneath her — or an immense but reasonable number of smaller objects (ST discretion).",
      "Expelling an object is a reflexive action and may come out of any part of her body. If this would force it into someone or something else, treat it as an attack with Stamina + Survival + Loki's Guise — almost certainly a surprise attack if the victim doesn't know she has this Devotion."]},

  {id:"chalice", name:"Chalice of the Overfull", rank:"neophyte", xp:1, cx:1122, cy:2250,
    tag:"Hold more blood than your body can.",
    stats:{Cost:"1 Willpower", Action:"Reflexive", Dice:"None"},
    desc:["Allows a vampire to store more Blood in her body than it can normally hold.",
      "She must already be holding as much Blood as she can normally contain to activate it. Then she can hold extra Blood Points equal to her Survival (or fewer, if she prefers).",
      "She suffers 1 bashing damage and loses 1 Speed for every two Blood Points held above her maximum, and those Health points can't be healed while she exceeds capacity. Her veins bulge unnaturally — mortals assume some disfiguring disease (ST may assess Social penalties)."]},

  {id:"flesh_unburdened", name:"The Flesh Unburdened", rank:"neophyte", xp:1, cx:506, cy:3144,
    tag:"Expel foreign objects from your body.",
    stats:{Cost:"1 Blood Point", Action:"Instant", Dice:"None"},
    desc:["The vampire can expel any foreign objects from her body — dirt, bullets, implants, and the like. She may choose to leave an object in, such as a prosthetic limb.",
      "This power does not allow a vampire to unstake herself."]},

  {id:"predatory_aspect", name:"Predatory Aspect", rank:"neophyte", xp:2, cx:2834, cy:2250,
    tag:"Assume aspects of animals, such as claws or hide.",
    stats:{Cost:"1 Blood Point (+1 per adaptation)", Action:"Reflexive", Duration:"Scene"},
    desc:["The vampire evokes a selection of bestial traits, enhancing her physical presence and abilities. On learning this gift she selects three adaptations from the list below; throughout the scene she can activate any or all by spending an additional Blood Point each.",
      "To change her chosen adaptations she must spend a day merged with the earth and expend a Blood Point per adaptation replaced.",
      "Adaptations: Aquatic (swim at run speed); Claws (1L Brawl weapons); Feral Senses (hear heartbeats, see/smell blood as if Blood Potency +2); Patagia / Weight of the Feather (reduce mass — glide 30 yds horizontally when falling ≥10, no fall damage); Prehensile Tail (extra grabbing limb, no fine motor); Quadrupedal (+4 Speed and double jumps on all fours); Camouflage (−4 dice vs your Stealth); Constricting Grip (victims lose 10-again to escape grapples); Hulk (+1 Size to Health, −2 to grapples against her); Extra Senses / Wall Crawling."]},

  {id:"echidnas_mark", name:"Echidna's Mark", rank:"neophyte", xp:2, cx:4000, cy:2752,
    tag:"Your claws cause great pain to those they wound.",
    stats:{Cost:"None", Action:"None", Duration:"Always on"},
    desc:["Users of this devotion inflict extremely painful wounds to quickly resolve fights and intimidate witnesses.",
      "Your Loki's Guise weapons are imbued with ocean salt. Her strikes inflict agonizing pain, and anyone she wounds suffers a −(½ Survival) modifier on their next action."]},

  {id:"morrigans_maw", name:"Morrigan's Maw", rank:"neophyte", xp:2, cx:1668, cy:3144,
    tag:"Form weapons from your own body.",
    stats:{Cost:"Varies (1 BP per weapon; 2 for large)", Action:"Reflexive", Duration:"Scene"},
    desc:["Form wicked weapons from your own body — sword blades, axes, spiked mauls, knife-bladed knuckles, and more dramatic implementations.",
      "Costs 1 Blood Point per weapon (larger weapons like two-handed swords and great axes cost 2). Each weapon takes 1 turn to form (large ones take 2).",
      "At Survival 4 you may spend an extra Blood Point on creation to make a weapon deal lethal damage. At Survival 5, weapons no longer take time to form."]},

  {id:"beasts_skin", name:"Beast's Skin", rank:"neophyte", xp:2, cx:5166, cy:3144,
    tag:"Fully transform into an animal.",
    stats:{Cost:"2 Blood Points", Action:"Instant", Duration:"Indefinite"},
    desc:["Transform into an animal you have previously consumed, of Size 1–7. You can maintain a number of forms equal to your Survival.",
      "To add or replace a form, consume the appropriate beast then slumber a full day and night merged with the earth.",
      "In animal form you adopt the beast's Physical Attributes, Skills, Size, Speed, and Health, and can move, sense, and attack as it does (some Physical Merits may be unavailable). You can still use your gifts as normal while transformed."]},

  {id:"skinstealers_rite", name:"Skinstealer's Rite", rank:"neophyte", xp:2, cx:6326, cy:3144,
    tag:"Fully transform into another human.",
    stats:{Cost:"1 Willpower", Action:"None", Duration:"Permanent"},
    desc:["Extends Beast's Skin to humans. When the vampire drains a mortal to death, he can memorize his form.",
      "Like an animal form, he takes on the victim's Physical traits (Attributes, Skills, Size, Speed, Health) but none of her memories or personality. It cannot replicate cosmetic changes such as piercings, tattoos, or body modifications; otherwise the form is a perfect replica at the time of death.",
      "Forms gained here count toward your Beast's Skin form limit. At Survival 5 you can transform into anything you last drank from — human, vampire, or animal."]},

  {id:"stygian_rest", name:"Stygian Rest", rank:"neophyte", xp:1, cx:7490, cy:3156,
    tag:"Spend willpower so you needn't spend blood to awaken.",
    stats:{Cost:"1 Willpower", Action:"Reflexive", Duration:"Day"},
    desc:["Spend a Willpower point when entering your Haven of Soil; if you do, there is no need to pay blood to awaken from sleep."]},

  {id:"tricksters_shedding", name:"The Trickster's Shedding", rank:"neophyte", xp:2, cx:4000, cy:3536,
    tag:"Make your transformations much quicker.",
    stats:{Cost:"1 additional Blood Point", Action:"Reflexive", Duration:"Scene"},
    desc:["Invoke a Loki's Guise transformation reflexively. There are two options:",
      "1) Spend an extra Blood Point on any transformation that would take an instant action to perform it reflexively instead.",
      "2) Activate Quickshift at any point in a scene (paying the normal transformation cost plus the extra Blood Point). Thereafter, that scene, you may activate the power at no additional cost. If you don't use it that scene, the Blood Points are simply lost."]},

  {id:"reforged_corpus", name:"Reforged Corpus", rank:"scion", xp:3, cx:506, cy:4040,
    tag:"Heal aggravated wounds without resting.",
    stats:{Cost:"1 Willpower / scene · 4 Blood Points per wound", Action:"Instant", Dice:"None"},
    desc:["Heal aggravated damage without resting, manually pressing your flesh back together through painful, ad hoc surgery.",
      "A single activation heals 1 point of aggravated damage immediately, rather than needing to do so in daysleep. If you can spend enough Vitae, it can even be activated more than once in the same turn."]},

  {id:"eviscerator_hands", name:"Eviscerator Hands", rank:"scion", xp:3, cx:1668, cy:4040,
    tag:"Your Protean weapons gain +1 AP.",
    stats:{},
    desc:["All your Protean-created weapons gain +1 AP."]},

  {id:"unnatural_aspect", name:"Unnatural Aspect", rank:"neophyte", xp:3, cx:2834, cy:4040,
    tag:"Assume stronger, horrific predatory aspects.",
    stats:{Cost:"1 Blood Point", Action:"None", Duration:"Scene"},
    desc:["The vampire can manifest truly horrific changes to her appearance. When she activates her Predatory Aspect, she may spend an extra Blood Point to assume one adaptation from the Unnatural Aspects list.",
      "To replace her chosen Unnatural Aspect she must sleep a full day and night in her Unmarked Grave, spending two Blood Points.",
      "Unnatural Aspects: Barbed Hands (+Loki's Guise dots to grapples; Damage move deals lethal); Hooked Hand (dig through soil/rock at ½ Speed); Horrid Talons (+2 lethal, AP2 on Brawl, lethal even to vampires); Rubbery Flesh (fit through any gap >1 inch; +Loki's Guise dots to contortion rolls); Wings (fly at full running Speed); Hollow Bones (use higher of Dex or Wits for Defense); Tough Hide (+2 general armor except vs banes); Horrible Musk (−Loki's Guise dots to victims' Defense); Hungry Hands (feed on a successful Brawl roll with skin contact); Tentacles (Brawl/Weaponry reach up to 5 m); Shark's Maw (a successful bite also deals 1 aggravated, even to vampires)."]},

  {id:"wretched_metamorphosis", name:"Wretched Metamorphosis", rank:"neophyte", xp:3, cx:4000, cy:4040,
    tag:"Apply predatory aspects to others.",
    stats:{Cost:"1 BP +1 per adaptation (1 Willpower optional)", Action:"Instant", Duration:"1 Hour"},
    desc:["Some vampires learn to command the flesh of others like they do animals, pulling horrors from their victims' skins. She must be touching her subject.",
      "Success: applies Predatory Aspect adaptations to a human, familiar, or vampire, up to Survival ÷ 2 (round up). Forms she doesn't know cost an additional Vitae. If the subject is a familiar, she can spend Willpower to make it permanent (then can't reuse on him except to swap or remove).",
      "Exceptional Success: the subject counts as twice-removed in blood sympathy for the duration. Failure: nothing happens. Dramatic Failure: a vampire subject frenzies against the caster; a human or familiar suffers cardiac arrest or another catastrophic event. Max subjects at once = Survival.",
      "Survival 4: instead of a supernatural change, reshape a subject to resemble a chosen person (may grant Merits like Striking Looks or Giant; subject gains dice equal to Survival on impersonation and ruse rolls). Survival 5: max subjects = 2× Survival. Survival 6: may bestow one Unnatural Aspect per subject (2 Blood Points; +1 if a form she doesn't know). Survival 7: max subjects = 4× Survival."]},

  {id:"skinwalker_curse", name:"Skinwalker Curse", rank:"neophyte", xp:2, cx:6328, cy:4050,
    tag:"Force someone into the form of an animal.",
    stats:{Cost:"3 Blood Points", Action:"Instant", Duration:"Night", Dice:"Sta + Survival + Loki's Guise vs Sta + Blood Potency (if unwilling)"},
    desc:["An animal minion can't match a human mind; a human body isn't a universal tool. Users of this devotion say: why not have both?",
      "Requirement: the victim must consume or be anointed by a Blood Point (included in cost). To bestow an animal form she doesn't have memorized, she must consume that beast's blood the same night.",
      "Success: the subject becomes an animal for the rest of the night, or until the vampire feeds/anoints her with another Blood Point. Exceptional: lasts additional nights equal to Survival. Failure: the body resists. Dramatic Failure: the vampire is forced into her own animal form for the scene and loses access to her other Loki's Guise powers.",
      "At Survival 7, this may become permanent with +2 Blood Points and a point of Willpower."]},

  {id:"nidavellirs_road", name:"Nidavellir's Road", rank:"neophyte", xp:2, cx:7490, cy:4050,
    tag:"Move through the ground while merged.",
    stats:{Cost:"1 Blood Point", Action:"Instant", Duration:"Scene"},
    desc:["Learn to move through the ground (or other substances) while within your unmarked grave.",
      "Activated when the vampire uses Unmarked Grave. For the rest of the scene, she can move at half her normal speed through any substance she's spent enough blood to sink into, relying on little more than her Vampire Senses for navigation."]},

  {id:"warded_form", name:"Warded Form", rank:"scion", xp:3, cx:506, cy:4944,
    tag:"Resist forced changes to your body.",
    stats:{Cost:"3 Blood Points", Action:"Reflexive", Dice:"None"},
    desc:["Vampires who've mastered solidifying or wholly shifting their form sometimes manifest this Devotion, which makes it difficult to cause any physical change to them.",
      "Any time a supernatural effect would change your body (shapeshifting, direct physical damage, physical Tilts, or attribute degradation), spend 3 Blood Points to roll a Clash of Wills to prevent or reverse it. You automatically know an effect is being attempted and what it will do — even if you choose not to spend the Vitae — though by default you don't know its source.",
      "Activated after any other innate defense (contesting a Discipline, withstanding a mage's spells, etc.)."]},

  {id:"ravager_claws", name:"Ravager Claws", rank:"ascendant", xp:1, cx:1668, cy:4946,
    tag:"Your natural weapons turn unnatural.",
    stats:{Cost:"1 Willpower", Action:"Reflexive", Duration:"Scene"},
    desc:["A Loki's Guise user's natural weapons are deadly and bestial; yours are downright unnatural.",
      "When wielding claws born of Unnatural Aspect, or weapons created from your Loki's Guise, you may spend a Willpower point to change the weapon modifier to +0 aggravated. These weapons ignore all armor not generated by Balder's Endurance."]},

  {id:"mercurial_form", name:"Mercurial Form", rank:"scion", xp:3, cx:2834, cy:4944,
    tag:"Shift freely between predatory and unnatural aspects.",
    stats:{Cost:"4 Blood Points", Action:"Instant", Duration:"Scene"},
    desc:["Gain the ability to fluidly shift between your predatory and unnatural aspects.",
      "For the scene you can manifest both Predatory Aspects and Unnatural Aspects without spending blood for each, and can reflexively change which manifestations are active, switching between options seamlessly."]},

  {id:"apex_form", name:"Apex Form", rank:"scion", xp:2, cx:4002, cy:4944,
    tag:"Upgrade one of your animal forms.",
    stats:{},
    desc:["Choose one animal you can transform into and upgrade its base stats.",
      "Add half your Survival as extra attribute points to the form, but you cannot raise the same attribute by more than two. Additionally, you may increase the form's natural-weapon damage by 2, or increase its armor by 2."]},

  {id:"animal_swarm", name:"Animal Swarm", rank:"scion", xp:3, cx:5166, cy:4944,
    tag:"Become a swarm of tiny creatures.",
    stats:{},
    desc:["When taking Beast's Skin, become a swarm of Size 0 or Size 1 creatures instead. You may perceive through any individual creature's senses, but the swarm acts as a single entity.",
      "The swarm may spread over five yards/meters per dot of Blood Potency; creatures beyond that range die and rapidly decompose. It moves at your Speed (modified for the creatures' Size) in any logical direction.",
      "The swarm limits visibility and hearing and causes panic — everyone within its area suffers the persistent Distracted Condition until they escape (ST may add swarm-appropriate features, e.g. rats gnawing barricades).",
      "It resists most harm: after armor and modifiers, the swarm takes at most one point of the appropriate damage type (two on an exceptional success). Fire, sunlight, explosions, and banes harm it normally."]},

  {id:"shapeshifter_binding", name:"Shapeshifter Binding", rank:"scion", xp:2, cx:6326, cy:4956,
    tag:"Force a target back into their native shape.",
    stats:{Cost:"3 Blood Points, 1 Willpower", Action:"Instant", Duration:"Scene", Dice:"Sta + Survival + Loki's Guise vs Sta + Blood Potency"},
